<div id="samples" class="music-player">
  <div class="music-player__inner">
    <p class="section-label fade-in">Примеры песен</p>
    <h2 class="section-heading fade-in">
      Послушайте, <em>что мы создаём</em>
    </h2>
    <p class="section-subtext fade-in">
      Каждая песня уникальна — написана специально для одного человека.
    </p>

    <!-- Player card -->
    <div class="player-card fade-in">
      <!-- Vinyl record -->
      <div class="vinyl" aria-hidden="true">
        <img
          src="{{ 'logo.jpeg' | asset_url }}"
          alt="{{ shop.name }}"
          class="vinyl__logo"
          width="56"
          height="56"
        >
      </div>

      <h3 class="player-card__title">Маша и кофе</h3>
      <p class="player-card__sub">День рождения · Поп-баллада</p>

      <!-- Progress bar -->
      <div class="progress-bar-wrap" role="slider" aria-label="Seek" aria-valuemin="0" aria-valuemax="100" aria-valuenow="0">
        <div class="progress-bar-fill"></div>
      </div>
      <div class="player-times">
        <span class="player-time-cur">0:00</span>
        <span class="player-time-dur">0:00</span>
      </div>

      <!-- Controls -->
      <div class="player-controls">
        <button class="player-btn-skip player-btn-prev" aria-label="Previous track">⏮</button>
        <button class="player-btn-play" aria-label="Play / Pause">
          <span class="play-icon"></span>
        </button>
        <button class="player-btn-skip player-btn-next" aria-label="Next track">⏭</button>
      </div>

      <!-- Dots -->
      <div class="player-dots">
        <button class="player-dot active" aria-label="Track 1"></button>
        <button class="player-dot"        aria-label="Track 2"></button>
      </div>
    </div>

    <!-- Track list -->
    <div class="track-list fade-in">
      <div class="track-item active" role="button" tabindex="0" aria-label="Play Маша и кофе">
        <span class="track-item__num">1</span>
        <div class="track-item__info">
          <div class="track-item__title">Маша и кофе</div>
          <div class="track-item__sub">День рождения · Поп-баллада</div>
        </div>
        <span class="track-item__indicator">▶</span>
      </div>
      <div class="track-item" role="button" tabindex="0" aria-label="Play Настя, ты моя вселенная">
        <span class="track-item__num">2</span>
        <div class="track-item__info">
          <div class="track-item__title">Настя, ты моя вселенная</div>
          <div class="track-item__sub">День рождения · Романтическая</div>
        </div>
        <span class="track-item__indicator">▶</span>
      </div>
    </div>

  </div>
</div>

{% schema %}
{
  "name": "Music Player",
  "settings": [],
  "presets": [
    { "name": "Music Player" }
  ]
}
{% endschema %}
