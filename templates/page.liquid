{% liquid
  assign legal_page_handle = ''
  assign legal_page_title = page.title

  if page.handle == 'privacy'
    assign legal_page_handle = 'privacy'
    assign legal_page_title = page.title | default: 'Политика конфиденциальности'
  elsif page.handle == 'terms'
    assign legal_page_handle = 'terms'
    assign legal_page_title = page.title | default: 'Условия использования'
  elsif page.handle == 'accessibility'
    assign legal_page_handle = 'accessibility'
    assign legal_page_title = page.title | default: 'Заявление о доступности'
  endif
%}

{% if legal_page_handle != blank %}
  {% render 'legal-page-shell', handle: legal_page_handle, title: legal_page_title, content_html: page.content %}
{% else %}
  <div class="page-wrap">
    <div class="page-breadcrumb">
      <a href="{{ routes.root_url }}" class="page-breadcrumb__home">← На главную</a>
    </div>

    <article class="page-content">
      <h1 class="page-content__title">{{ page.title }}</h1>
      <div class="rte page-content__body">{{ page.content }}</div>
    </article>
  </div>
{% endif %}
