{% liquid
  assign request_path = request.path | downcase
  assign legal_page_handle = ''
  assign legal_page_title = policy.title

  if request_path contains '/policies/privacy-policy'
    assign legal_page_handle = 'privacy'
    assign legal_page_title = policy.title | default: 'Политика конфиденциальности'
  elsif request_path contains '/policies/terms-of-service'
    assign legal_page_handle = 'terms'
    assign legal_page_title = policy.title | default: 'Условия использования'
  endif
%}

{% if legal_page_handle != blank %}
  {% render 'legal-page-shell', handle: legal_page_handle, title: legal_page_title, content_html: policy.body %}
{% else %}
  <div class="page-wrap">
    <div class="page-breadcrumb">
      <a href="{{ routes.root_url }}" class="page-breadcrumb__home">← На главную</a>
    </div>

    <article class="page-content">
      <h1 class="page-content__title">{{ policy.title }}</h1>
      <div class="rte page-content__body">{{ policy.body }}</div>
    </article>
  </div>
{% endif %}
